{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"strict": true,
		"target": "ES6",
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-native",
		"types": [
			"jest"
		],
		"lib": [
			"dom",
			"esnext"
		],
		"noEmit": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@/assets/*": [
				"./assets/*"
			],
			"@/db/*": [
				"./src/db/*"
			],
		}
	},
	"include": [
		"src",
		"tests",
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts"
	],
	"exclude": [
		"node_modules"
	]
}