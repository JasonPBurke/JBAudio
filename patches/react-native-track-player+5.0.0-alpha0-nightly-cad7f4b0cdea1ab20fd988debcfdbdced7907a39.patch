+    private fun readAutoCache(): JSONObject? {
+        return try {
+            val file = File(filesDir, "android_auto_cache.json")
+            if (file.exists()) JSONObject(file.readText()) else null
+        } catch (e: Exception) {
+            null
+        }
+    }
+
+    private fun buildCategoryItem(id: String, title: String): MediaItem =
+        MediaItem.Builder()
+            .setMediaId(id)
+            .setMediaMetadata(
+                MediaMetadata.Builder()
+                    .setIsBrowsable(true)
+                    .setIsPlayable(false)
+                    .setTitle(title)
+                    .build()
+            ).build()
+
+    private fun buildBookItems(arr: JSONArray): ImmutableList<MediaItem> {
+        val builder = ImmutableList.builder<MediaItem>()
+        for (i in 0 until arr.length()) {
+            val book = arr.getJSONObject(i)
+            val bookId = book.optString("bookId", "")
+            if (bookId.isEmpty()) continue
+            val artworkUri = book.optString("artwork", "")
+            val metaBuilder = MediaMetadata.Builder()
+                .setIsBrowsable(false)
+                .setIsPlayable(true)
+                .setTitle(book.optString("title", "Unknown"))
+                .setArtist(book.optString("author", ""))
+            if (artworkUri.isNotEmpty()) {
+                metaBuilder.setArtworkUri(Uri.parse(artworkUri))
+            }
+            builder.add(
+                MediaItem.Builder()
+                    .setMediaId(bookId)
+                    .setMediaMetadata(metaBuilder.build())
+                    .build()
+            )
+        }
+        return builder.build()
+    }
+
+    private fun buildBrowseChildren(parentId: String): ImmutableList<MediaItem> {
+        return when {
+            parentId == "root" -> ImmutableList.of(
+                buildCategoryItem("recently_added", "Recently Added"),
+                buildCategoryItem("all_books", "All Books"),
+                buildCategoryItem("by_author", "By Author"),
+            )
+            parentId == "recently_added" -> {
+                val arr = readAutoCache()?.optJSONArray("recentlyAdded")
+                    ?: return ImmutableList.of()
+                buildBookItems(arr)
+            }
+            parentId == "all_books" -> {
+                val arr = readAutoCache()?.optJSONArray("allBooks")
+                    ?: return ImmutableList.of()
+                buildBookItems(arr)
+            }
+            parentId == "by_author" -> {
+                val authors = readAutoCache()?.optJSONArray("authors")
+                    ?: return ImmutableList.of()
+                val builder = ImmutableList.builder<MediaItem>()
+                for (i in 0 until authors.length()) {
+                    val author = authors.getJSONObject(i)
+                    val name = author.optString("name", "")
+                    if (name.isNotEmpty()) {
+                        builder.add(buildCategoryItem("author__$name", name))
+                    }
+                }
+                builder.build()
+            }
+            parentId.startsWith("author__") -> {
+                val authorName = parentId.removePrefix("author__")
+                val authors = readAutoCache()?.optJSONArray("authors")
+                    ?: return ImmutableList.of()
+                for (i in 0 until authors.length()) {
+                    val author = authors.getJSONObject(i)
+                    if (author.optString("name") == authorName) {
+                        val books = author.optJSONArray("books")
+                            ?: return ImmutableList.of()
+                        return buildBookItems(books)
+                    }
+                }
+                ImmutableList.of()
+            }
+            else -> ImmutableList.of()
+        }
+    }
+
+    private fun isCategoryId(id: String): Boolean =
+        id == "root" || id == "recently_added" || id == "all_books" ||
+        id == "by_author" || id.startsWith("author__")
+
